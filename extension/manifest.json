{
  "manifest_version": 3,
  "name": "Antigravity Leech (Singularity)",
  "version": "2.0",
  "description": "Passive Logic Assessment Infiltration Node. Captures traffic for the Antigravity Singularity Engine.",
  "permissions": [
    "debugger",
    "tabs",
    "storage",
    "webRequest"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_title": "Antigravity Leech"
  }
}
